generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Currency {
  USD
  EUR
}

model Customer {
  id        String     @id @default(uuid())
  name      String
  transfers Transfer[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Transfer {
  id           String   @id @default(uuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  amount       Float
  currency     Currency
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
